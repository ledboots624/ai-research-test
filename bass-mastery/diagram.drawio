        <mxCell id="title_bar" value="Bass Mastery: ロック＆ファンク・ベース上達の科学的ロードマップ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2d3748;strokeColor=none;fontColor=#ffffff;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
