        <!-- Section 1: Core Techniques -->
        <mxCell id="sec1_header" value="1. 核心的奏法 (Techniques)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ebf4ff;strokeColor=#3182ce;fontColor=#2d3748;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
