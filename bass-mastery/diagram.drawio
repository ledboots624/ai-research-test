        </mxCell>
        <mxCell id="node1_1" value="指弾き (2-Finger)&#xa;基本のオルタネイトと&#xa;レイキング活用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ebf4ff;strokeColor=#3182ce;shadow=1;fontSize=12;fontColor=#2d3748;" vertex="1" parent="1">
