<?xml version="1.0" encoding="UTF-8"?>
<mxfile>
  <diagram id="mcp-security-landscape" name="MCP Security Landscape">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title Bar -->
        <mxCell id="2" value="MCP (Model Context Protocol) Security Landscape" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2d3748;fontColor=#ffffff;fontSize=22;fontStyle=1;strokeColor=none;align=left;spacingLeft=20;" vertex="1" parent="1">
