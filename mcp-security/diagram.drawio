        <!-- Risk Area Background -->
        <mxCell id="3" value="主要リスク要因 (Threat Landscape)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f5;strokeColor=#fc8181;verticalAlign=top;fontSize=14;fontStyle=1;fontColor=#c53030;arcSize=4;" vertex="1" parent="1">
