<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io">
  <diagram id="ResearchDiagram" name="GuitarShops">
    <mxGraphModel background="#ffffff" dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="ギターを演奏できるお店リサーチ結果 (東京23区・東武線)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d3748;fontColor=#ffffff;fontSize=22;fontStyle=1;strokeColor=none;align=left;spacingLeft=20;arcSize=8;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="760" height="60" as="geometry" />
        </mxCell>
        <mxCell id="profile" value="ターゲット属性&#xa;・レベル: 上級者&#xa;・スタイル: 一人飛び込み" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7fafc;strokeColor=#a0aec0;fontColor=#333333;fontSize=12;arcSize=8;shadow=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="conditions" value="必須条件 (MUST)&#xa;・ギター常備 (持参不要)&#xa;・セッション/オープンマイク有&#xa;・予約不要" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7fafc;strokeColor=#a0aec0;fontColor=#333333;fontSize=12;arcSize=8;shadow=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="120" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="area" value="調査エリア&#xa;・Primary: 東京23区&#xa;・Secondary: 東武線沿線" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7fafc;strokeColor=#a0aec0;fontColor=#333333;fontSize=12;arcSize=8;shadow=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="120" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rec_header" value="推奨店舗 (Recommended)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4a5568;fontColor=#ffffff;fontSize=14;fontStyle=1;strokeColor=none;shadow=0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="760" height="30" as="geometry" />
        </mxCell>
        <mxCell id="shop1" value="【最優先】BECKアキバ (秋葉原)&#xa;-----------------------------&#xa;・楽器無料常設 (エレキ/アコギ)&#xa;・予約不要でジャムセッション&#xa;・1,500円〜 / 初心者〜上級者OK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fff4;strokeColor=#38a169;fontColor=#333333;fontSize=12;fontStyle=1;arcSize=8;shadow=1;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="280" y="300" width="280" height="110" as="geometry" />
        </mxCell>
        <mxCell id="shop2" value="【上級者向】J-flow (錦糸町)&#xa;-----------------------------&#xa;・ジャズセッション専門店&#xa;・ハイレベルな演奏環境&#xa;・セッションホスト常駐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ebf4ff;strokeColor=#3182ce;fontColor=#333333;fontSize=12;arcSize=8;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="200" height="110" as="geometry" />
        </mxCell>
        <mxCell id="shop3" value="【穴場】ピグノーズ (中野)&#xa;-----------------------------&#xa;・ジャムセッション中心&#xa;・飛び込み参加可能&#xa;・楽器あり" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ebf4ff;strokeColor=#3182ce;fontColor=#333333;fontSize=12;arcSize=8;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="300" width="200" height="110" as="geometry" />
        </mxCell>
        <mxCell id="caution" value="⚠ 東武線沿線エリア (草加・越谷・北千住)&#xa;ギター常備・オープンセッションの確実な情報が不足。&#xa;ライブバーは存在するが、事前確認が必須。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7d7;strokeColor=#e53e3e;fontColor=#c53030;fontSize=12;arcSize=8;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="450" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="footer" value="結論: 「BECKアキバ」が条件充足度No.1。ジャズ志向なら「J-flow」。東武線方面は要開拓。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d3748;fontColor=#ffffff;fontSize=14;fontStyle=1;strokeColor=none;arcSize=8;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="760" height="40" as="geometry" />
        </mxCell>
