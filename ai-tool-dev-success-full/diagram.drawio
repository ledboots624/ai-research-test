          <mxGeometry x="80" y="200" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="node_ai" value="AI / LLM&#xa;(確率論的・Probabilistic)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7d7;strokeColor=#e53e3e;fontColor=#c53030;fontSize=12;shadow=1;arcSize=8;" vertex="1" parent="1">
