        <mxCell id="node_conflict" value="概念の不一致&#xa;(Integrity Risk)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fffff0;strokeColor=#d69e2e;fontColor=#744210;size=15;fontSize=11;" vertex="1" parent="1">
