        <mxCell id="title" value="AIツール開発成功パイプライン：フルスタックエンジニア視点" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d3748;strokeColor=none;fontColor=#ffffff;fontSize=22;fontStyle=1;shadow=1;arcSize=10;" vertex="1" parent="1">
